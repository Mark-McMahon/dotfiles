# ============================================
# Oh My Zsh Configuration
# ============================================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git)
source $ZSH/oh-my-zsh.sh

# ============================================
# PATH Configuration
# ============================================
export PATH="/opt/homebrew/bin:$PATH"
export PATH="$PATH:/Users/markmcmahon/.local/bin"
export PATH="/opt/homebrew/opt/postgresql@14/bin:$PATH"
export PATH="$PATH:/Users/markmcmahon/go/bin"  # Static Go path 
export PATH="$PATH:/Users/markmcmahon/manual-installs/jasypt-1.9.3/bin"

# ============================================
# Python Configuration (pyenv)
# ============================================
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init --path)"
eval "$(pyenv init -)"

# ============================================
# Node Configuration (nvm)
# ============================================
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ============================================
# Java Configuration (SDKMAN)
# ============================================
export JAVA_HOME=/Users/markmcmahon/Downloads/jdk-21.0.3.jdk/Contents/Home
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

# ============================================
# Homebrew
# ============================================
eval "$(/opt/homebrew/bin/brew shellenv)"

# ============================================
# Environment Variables
# ============================================
ENVIRONMENT=ss-stage
export AWS_PROFILE=ss-stage

# ============================================
# Utility Functions
# ============================================
jasypt() {
  local action=$1
  [ -z $action ] && { echo "usage: jasypt [encrypt|decrypt] [args]"; return; }
  shift
  bash /Users/markmcmahon/manual-installs/jasypt-1.9.3/bin/${action}.sh \
    algorithm="PBEWITHHMACSHA512ANDAES_256" \
    ivGeneratorClassName="org.jasypt.iv.RandomIvGenerator" \
    verbose="false" "$@"
}

ptk() {
  if [ -z "$1" ]; then
    echo "Usage: ptk <test_name>"
    return 1
  fi
  local test_name="$1"
  pt -k "$test_name"
}

ptkh() {
  if [ -z "$1" ]; then
    echo "Usage: ptkh <test_name>"
    return 1
  fi
  local test_name="$1"
  pt -k "$test_name" --headed
}

# ============================================
# Aliases - General
# ============================================
alias reload="source ~/.zshrc"
alias cc="claude --dangerously-skip-permissions"

# ============================================
# Aliases - Docker
# ============================================
alias dpt='docker compose run --rm ap'
alias dptk='docker compose run --rm ap ptk'
alias dptkh='docker compose run --rm ap ptkh'

# ============================================
# Aliases - SDK/Java
# ============================================
alias sdk17="sdk use java 17.0.12-amzn"
alias sdk21="sdk use java 21.0.3-amzn"

# ============================================
# Aliases - Python/Testing
# ============================================
alias pt="pipenv run pytest"


# ============================================================
# Machine-local config (secrets / work tokens) - untracked
# ============================================================
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
